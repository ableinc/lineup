{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "lineup",
	"version": "0.1.0",
	"identifier": "com.capabletechnology.lineup",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "lineup",
				"width": 1200,
				"height": 720
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
